{
    "__inputs": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "description": "",
        "type": "datasource",
        "pluginId": "prometheus"
      },
      {
        "name": "DS_MYSQL",
        "label": "MySQL",
        "description": "",
        "type": "datasource",
        "pluginId": "mysql"
      }
    ],
    "__requires": [
      {
        "type": "grafana",
        "id": "grafana",
        "name": "Grafana",
        "version": "8.0.0"
      },
      {
        "type": "datasource",
        "id": "prometheus",
        "name": "Prometheus",
        "version": "1.0.0"
      },
      {
        "type": "datasource",
        "id": "mysql",
        "name": "MySQL",
        "version": "1.0.0"
      }
    ],
    "id": null,
    "title": "MLOps Compliance Risk Dashboard",
    "tags": ["mlops", "compliance"],
    "style": "dark",
    "timezone": "browser",
    "editable": true,
    "hideControls": false,
    "graphTooltip": 0,
    "panels": [
      {
        "title": "API Health",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
      },
      {
        "title": "Request Rate",
        "type": "graph",
        "datasource": "${DS_PROMETHEUS}",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{job='fastapi'}[5m]))",
            "legendFormat": "Requests/s"
          }
        ]
      },
      {
        "title": "Error Rate (5xx)",
        "type": "graph",
        "datasource": "${DS_PROMETHEUS}",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{job='fastapi', status_code=~'5..'}[5m])) / sum(rate(http_requests_total{job='fastapi'}[5m]))",
            "legendFormat": "Error Ratio"
          }
        ]
      },
      {
        "title": "Authentication",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
      },
      {
        "title": "User Registrations",
        "type": "stat",
        "datasource": "${DS_MYSQL}",
        "gridPos": { "h": 4, "w": 8, "x": 0, "y": 10 },
        "targets": [
          {
            "format": "table",
            "rawSql": "SELECT COUNT(*) as registrations FROM users WHERE created_at >= NOW() - INTERVAL 1 DAY",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "thresholds": {
              "mode": "absolute",
              "steps": [ { "color": "green", "value": null } ]
            }
          }
        }
      },
      {
        "title": "Active Users (last 24h)",
        "type": "stat",
        "datasource": "${DS_MYSQL}",
        "gridPos": { "h": 4, "w": 8, "x": 8, "y": 10 },
        "targets": [
          {
            "format": "table",
            "rawSql": "SELECT COUNT(DISTINCT user_id) FROM auth_logs WHERE action='login' AND timestamp >= NOW() - INTERVAL 1 DAY",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none"
          }
        }
      },
      {
        "title": "Login Attempts",
        "type": "graph",
        "datasource": "${DS_PROMETHEUS}",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
        "targets": [
          {
            "expr": "rate(login_attempts_total[5m])",
            "legendFormat": "Attempts"
          }
        ]
      },
      {
        "title": "Model Performance",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
      },
      {
        "title": "AUC over time",
        "type": "graph",
        "datasource": "${DS_PROMETHEUS}",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
        "targets": [
          {
            "expr": "model_auc",
            "legendFormat": "AUC"
          }
        ]
      },
      {
        "title": "Accuracy / Precision / Recall",
        "type": "graph",
        "datasource": "${DS_PROMETHEUS}",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
        "targets": [
          { "expr": "model_accuracy", "legendFormat": "Accuracy" },
          { "expr": "model_precision", "legendFormat": "Precision" },
          { "expr": "model_recall", "legendFormat": "Recall" }
        ]
      },
      {
        "title": "Model Versions & Drift",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }
      },
      {
        "title": "Model Version Timeline",
        "type": "table",
        "datasource": "${DS_MYSQL}",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
        "targets": [
          {
            "format": "table",
            "rawSql": "SELECT version, created_at, metrics, notes FROM model_versions ORDER BY version DESC LIMIT 10",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Prediction Distribution",
        "type": "graph",
        "datasource": "${DS_PROMETHEUS}",
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 28 },
        "targets": [
          {
            "expr": "sum(rate(prediction_count{result='positive'}[1h]))",
            "legendFormat": "Positive"
          },
          {
            "expr": "sum(rate(prediction_count{result='negative'}[1h]))",
            "legendFormat": "Negative"
          }
        ]
      },
      {
        "title": "Prediction Drift Score",
        "type": "stat",
        "datasource": "${DS_PROMETHEUS}",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 28 },
        "targets": [
          {
            "expr": "drift_score",
            "legendFormat": "Drift"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 0.1 },
                { "color": "red", "value": 0.2 }
              ]
            }
          }
        }
      },
      {
        "title": "Dependencies & System",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 }
      },
      {
        "title": "Container CPU Usage",
        "type": "graph",
        "datasource": "${DS_PROMETHEUS}",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 37 },
        "targets": [
          {
            "expr": "rate(container_cpu_usage_seconds_total{name='compliance_api'}[5m])",
            "legendFormat": "CPU"
          }
        ]
      },
      {
        "title": "Container Memory Usage",
        "type": "graph",
        "datasource": "${DS_PROMETHEUS}",
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 37 },
        "targets": [
          {
            "expr": "container_memory_usage_bytes{name='compliance_api'}",
            "legendFormat": "Memory"
          }
        ]
      },
      {
        "title": "Python Package Versions",
        "type": "table",
        "datasource": "${DS_MYSQL}",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 37 },
        "targets": [
          {
            "format": "table",
            "rawSql": "SELECT package, version, installed_at FROM dependencies ORDER BY installed_at DESC LIMIT 10",
            "refId": "A"
          }
        ]
      }
    ],
    "refresh": "10s",
    "schemaVersion": 27,
    "version": 1
  }